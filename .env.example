# ═══════════════════════════════════════════════════════════
# LeadHarvester Pro - Configuration
# Copy this to .env and fill in your values
# ═══════════════════════════════════════════════════════════

# OpenAI API Key (for AI-powered data cleaning & enrichment)
OPENAI_API_KEY=sk-your-openai-key-here

# Browser Settings
HEADLESS=true
SLOW_MO=0

# Rate Limiting (milliseconds between actions)
MIN_DELAY=2000
MAX_DELAY=5000

# Proxy (optional - for high-volume scraping)
# Format: http://user:pass@host:port
PROXY_URL=
# Or a file with one proxy per line
PROXY_LIST_FILE=

# Output Settings
OUTPUT_DIR=./data/processed
RAW_DIR=./data/raw
MAX_RESULTS=100

# Logging
LOG_LEVEL=INFO
